{# Inlining helper for `ec_targeted`. Walks the contract's loaded
   profile corpus to find the cited doc + section, then emits its
   body. Falls through to a placeholder if the section isn't found
   (the validator should have rejected this earlier; the placeholder
   protects render from crashing on stale persistence). #}

{% macro _inline_standards_section(contract, ref) -%}
{% set _doc = namespace(found=none) -%}
{% for profile in contract.standards.profiles -%}
{% for doc in profile.docs -%}
{% if doc.repo_relative == ref.doc_path -%}
{% set _doc.found = doc -%}
{% endif -%}
{% endfor -%}
{% endfor -%}
{% if _doc.found is not none -%}
**`{{ ref.doc_path }}` § {{ ref.section }}** (profile: {{ _doc.found.profile }}, importance: {{ _doc.found.importance }})

```
{{ _doc.found.body[:6000] }}
```
{%- else -%}
**`{{ ref.doc_path }}` § {{ ref.section }}** (doc body unavailable — citation may be stale)
{%- endif -%}
{%- endmacro %}

{% macro _inline_architecture_section(contract, ref) -%}
{% set _doc = namespace(found=none) -%}
{% for doc in contract.architecture.corpus.docs -%}
{% if doc.repo_relative == ref.doc_path -%}
{% set _doc.found = doc -%}
{% endif -%}
{% endfor -%}
{% if _doc.found is not none -%}
**`{{ ref.doc_path }}` § {{ ref.section }}** (architecture doc, title: {{ _doc.found.title }})

```
{{ _doc.found.body[:6000] }}
```
{%- else -%}
**`{{ ref.doc_path }}` § {{ ref.section }}** (doc body unavailable — citation may be stale)
{%- endif -%}
{%- endmacro %}

